# Force LF on files that run inside Linux containers — a CRLF shebang
# breaks the interpreter ("bad interpreter: No such file or directory").
*.sh            text eol=lf
docker-entrypoint.sh text eol=lf
Dockerfile      text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
Caddyfile       text eol=lf
*.conf          text eol=lf
