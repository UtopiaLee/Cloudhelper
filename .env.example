# CloudHelper 配置 (Docker 部署)
# 复制此文件为 .env 后修改值

# === 必填 ===
# 主密钥，用于加密云凭据。改成强随机字符串
MASTER_PASSWORD=change-this-to-a-long-random-string

# === 强烈建议 ===
# 访问令牌。留空则关闭鉴权（仅本机访问时可以留空）
# 设置后访问 Web UI 需要先输入此 token
ACCESS_TOKEN=

# === 可选 ===
# 前端对外端口（默认 8080）
FRONTEND_PORT=8080

# 基础 docker-compose.yml 走明文 HTTP，默认只绑定本机回环 127.0.0.1，
# 不对外网发布。对外暴露请改用下面的 HTTPS overlay（方案 A/B）走真正的 TLS。
# 仅当你确实清楚要把明文端口发布到其它接口时，才改成 0.0.0.0（不推荐，密码/cookie/SSH 流量明文）。
FRONTEND_BIND=127.0.0.1

# 时区
TZ=Asia/Shanghai

# Webhook 通知 URL（流量超限/任务执行时推送）
NOTIFY_WEBHOOK_URL=

# CORS 允许的前端来源（默认包含本机）
CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# === HTTPS 方案 A：Caddy 自动签 LE 证书（仅用 docker-compose.https.yml 时）===
CADDY_DOMAIN=
CADDY_EMAIL=

# === HTTPS 方案 B：手动证书（仅用 docker-compose.tls.yml 时）===
# 宿主机上证书 + 私钥的绝对路径
# 例：/etc/letsencrypt/live/example.com/fullchain.pem
TLS_CERT_PATH=
TLS_KEY_PATH=
HTTP_PORT=80
HTTPS_PORT=443
